{
  "name": "keel",
  "version": "0.1.0",
  "description": "LLM optimization gateway with shadow-eval routing, semantic caching, budget guardrails, and multi-provider failover.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20.11.0"
  },
  "packageManager": "npm@10.9.0",
  "bin": {
    "keel": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "start": "node dist/server/index.js",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "bench": "tsx scripts/benchmark.ts",
    "db:migrate": "tsx scripts/migrate.ts",
    "docker:build": "docker build -t keel:local -f docker/Dockerfile .",
    "docker:up": "docker compose -f docker/docker-compose.yml up --build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "@hono/node-server": "^1.13.7",
    "hono": "^4.6.13",
    "openai": "^4.76.0",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.1",
    "@types/pg": "^8.11.10",
    "@vitest/coverage-v8": "^2.1.8",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
