{
  "format_version": "1.16.0",
  "minecraft:entity": {
    "description": {
      "identifier": "dh:bunny",
      "is_spawnable": true,
      "is_summonable": true,
      "is_experimental": false
    },
    "component_groups": {
      "dh:wild": {
        "minecraft:tameable": {
          "probability": 0.5,
          "tame_items": ["minecraft:carrot", "minecraft:golden_carrot"],
          "tame_event": { "event": "dh:on_tame", "target": "self" }
        }
      },
      "dh:tamed": {
        "minecraft:is_tamed": {},
        "minecraft:sittable": {},
        "minecraft:behavior.follow_owner": {
          "priority": 3,
          "speed_multiplier": 1.3,
          "start_distance": 4,
          "stop_distance": 2
        },
        "minecraft:behavior.stay_while_sitting": {
          "priority": 1
        }
      },
      "dh:baby": {
        "minecraft:is_baby": {},
        "minecraft:scale": { "value": 0.5 }
      }
    },
    "components": {
      "minecraft:type_family": { "family": ["dh_bunny", "mob"] },
      "minecraft:health": { "value": 12, "max": 12 },
      "minecraft:collision_box": { "width": 0.5, "height": 0.4 },
      "minecraft:physics": {},
      "minecraft:pushable": { "is_pushable": true, "is_pushable_by_piston": true },
      "minecraft:movement": { "value": 0.3 },
      "minecraft:navigation.walk": {
        "can_path_over_water": true,
        "avoid_water": true,
        "avoid_damage_blocks": true
      },
      "minecraft:movement.basic": {},
      "minecraft:jump.static": { "jump_power": 0.6 },
      "minecraft:behavior.float": { "priority": 0 },
      "minecraft:behavior.random_stroll": {
        "priority": 6,
        "speed_multiplier": 1.0
      },
      "minecraft:behavior.random_look_around": { "priority": 7 },
      "minecraft:behavior.look_at_player": {
        "priority": 5,
        "look_distance": 6,
        "probability": 0.04
      },
      "minecraft:behavior.tempt": {
        "priority": 4,
        "speed_multiplier": 1.4,
        "items": ["minecraft:carrot", "minecraft:golden_carrot"]
      },
      "minecraft:leashable": { "soft_distance": 4, "hard_distance": 6, "max_distance": 10 },
      "minecraft:damage_sensor": {
        "triggers": [
          {
            "cause": "fall",
            "deals_damage": false
          }
        ]
      },
      "minecraft:scale": { "value": 0.6 },
      "minecraft:despawn": { "despawn_from_distance": {} }
    },
    "events": {
      "minecraft:entity_spawned": {
        "add": { "component_groups": ["dh:wild", "dh:baby"] }
      },
      "dh:on_tame": {
        "remove": { "component_groups": ["dh:wild"] },
        "add": { "component_groups": ["dh:tamed"] }
      }
    }
  }
}
