# ============================================================
# Polymarket Moonshot Bot — environment configuration
# Copy to .env and fill in. NEVER commit .env.
# ============================================================

# ---- Polymarket / Polygon ----
# Private key of the EOA that funded the Polymarket proxy wallet.
# For email/magic-link Polymarket users, this is the key of the
# browser wallet you added. KEEP SECRET.
POLYMARKET_PRIVATE_KEY=0xyourprivatekeyhere

# Your Polymarket *proxy wallet* address (NOT your EOA).
# Find it at https://polymarket.com/ -> profile -> deposit address.
POLYMARKET_PROXY_ADDRESS=0xyourproxywalletaddress

# Signature type:
#   1 = email/magic (most retail users)
#   2 = browser wallet (MetaMask etc)
POLYMARKET_SIG_TYPE=1

# CLOB host (leave default unless Polymarket moves it)
POLYMARKET_CLOB_HOST=https://clob.polymarket.com

# Polygon chain id (do not change)
POLYGON_CHAIN_ID=137

# ---- Bankroll / risk ----
STARTING_BANKROLL_USDC=100.0
TARGET_BANKROLL_USDC=1000.0
HARD_SHUTDOWN_USDC=20.0          # bot halts forever below this
DAILY_DRAWDOWN_PCT=0.35          # 35% daily loss -> circuit breaker
MAX_POSITION_FRAC=0.40           # max 40% of bankroll in one market
MAX_CONCURRENT_POSITIONS=3
KELLY_FRACTION=1.5               # 1.5x Kelly = moonshot sizing
MIN_EDGE_BPS=400                 # 4% minimum edge to enter

# ---- Claude API (news / non-crypto reasoning) ----
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-haiku-4-5-20251001
CLAUDE_MAX_SPEND_USD_DAILY=5.0

# ---- Telegram notifications ----
TELEGRAM_BOT_TOKEN=1234567890:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
TELEGRAM_CHAT_ID=123456789

# ---- Feature flags ----
ENABLE_CRYPTO_LAG=true
ENABLE_NEWS_REACTOR=true
ENABLE_RESOLVER_SNIPER=true
DRY_RUN=false                    # if true, logs trades but does not send them

# ---- Data feeds ----
BINANCE_WS_URL=wss://stream.binance.com:9443/stream
CRYPTO_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,XRPUSDT,DOGEUSDT

# ---- Runtime ----
LOG_LEVEL=INFO
STATE_DIR=./state
POLL_INTERVAL_SECONDS=15
