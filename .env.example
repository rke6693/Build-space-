# ---- Server ----
NODE_ENV=development
PORT=8787
LOG_LEVEL=info

# ---- Gateway auth ----
# Comma-separated list of API keys clients use to call the gateway.
# Generate with: node -e "console.log('kl_'+require('crypto').randomBytes(24).toString('hex'))"
KEEL_API_KEYS=kl_devkey_replace_me

# ---- Upstream providers ----
# Only include the ones you use. Missing keys disable that provider.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- Storage ----
# Optional. Without Postgres, Keel falls back to in-memory cache + stats (dev only).
DATABASE_URL=postgres://keel:keel@localhost:5432/keel

# ---- Semantic cache ----
# Provider used to embed prompts for the semantic cache. Set to "off" to disable.
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
# Cosine similarity threshold above which a cache hit is returned. 0.0-1.0.
SEMANTIC_CACHE_THRESHOLD=0.93
SEMANTIC_CACHE_TTL_SECONDS=86400

# ---- Shadow-eval routing ----
# Percentage of eligible requests (0-100) that also get sent to a candidate model
# for quality comparison. Candidate response is NOT returned to the client.
SHADOW_SAMPLE_PERCENT=5
# Judge model used to score primary vs candidate. Use a cheap fast model.
SHADOW_JUDGE_MODEL=claude-haiku-4-5
# Minimum average judge score (0-1) over the rolling window before auto-promoting
# the candidate to primary. Set high to be conservative. 0 = never auto-promote.
SHADOW_PROMOTION_THRESHOLD=0.92
SHADOW_WINDOW_SIZE=200
# JSON map of primary -> candidate model ids. Shadow is off until you set one.
# Example: {"claude-sonnet-4-6":"claude-haiku-4-5","gpt-4o":"gpt-4o-mini"}
SHADOW_CANDIDATES={}

# ---- Routing overrides ----
# JSON map of requested-model -> actually-served-model. Use this to promote a
# shadow candidate to primary once it hits your parity threshold.
# Example: {"claude-sonnet-4-6":"claude-haiku-4-5"}
ROUTING_OVERRIDES={}

# ---- Budget guardrails ----
# Default monthly USD budget per API key. Override per-key in Postgres.
DEFAULT_MONTHLY_BUDGET_USD=100
# Hard block requests when budget exceeded? If false, logs a warning but allows.
BUDGET_HARD_BLOCK=true
