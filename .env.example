# Market Edge Daily — Environment Configuration
# Copy to .env and fill in your API keys

# ========== Required for full functionality ==========

# OpenAI API key (for LLM research and briefing generation)
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Serper API key (for web search research)
# Get one at: https://serper.dev (free tier: 2500 queries/month)
SERPER_API_KEY=your-serper-key-here

# ========== Email Delivery (choose one) ==========

# Buttondown (recommended — newsletter platform, handles subscribers)
# Get one at: https://buttondown.email/settings
BUTTONDOWN_API_KEY=
# Set to true to save as draft instead of sending immediately
DELIVERY_DRAFT_MODE=false

# Resend (transactional email — you manage subscriber list)
# Get one at: https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=newsletter@yourdomain.com
RESEND_TO_EMAILS=subscriber1@example.com,subscriber2@example.com

# ========== Alerting ==========

# Webhook URL for alerts (Slack incoming webhook, Discord webhook, or generic)
ALERT_WEBHOOK_URL=
# Type: slack, discord, or generic
ALERT_WEBHOOK_TYPE=slack
# Minimum level to send: info, warning, error
ALERT_MIN_LEVEL=warning

# ========== LLM Settings ==========
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.3

# ========== Paths ==========
NEWSLETTER_DIR=~/newsletter
TRACKER_DB=~/newsletter/predictions.json
ACCURACY_DIR=~/newsletter/accuracy

# ========== Market Settings ==========
RESOLUTION_WINDOW_DAYS=14
TOP_DIVERGENCE_COUNT=5
BRIEFING_WORD_TARGET=500

# ========== Schedule ==========
DAILY_RUN_HOUR=5
DAILY_RUN_MINUTE=0

# ========== Cache ==========
# Search cache TTL in seconds (default: 6 hours = 21600)
SEARCH_CACHE_TTL=21600
