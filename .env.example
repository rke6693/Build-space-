# OmniSight Prediction Market Infrastructure
# Copy to .env and fill in values

# Server
HOST=0.0.0.0
PORT=8000
ENV=development
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://omnisight:omnisight@localhost:5432/omnisight
REDIS_URL=redis://localhost:6379/0

# Platform API Keys
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
KALSHI_API_KEY=
KALSHI_API_SECRET=
PINNACLE_API_KEY=
BETFAIR_API_KEY=
BETFAIR_SESSION_TOKEN=

# Auth
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Stripe (Billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Rate Limits (per minute)
FREE_TIER_RATE_LIMIT=60
PRO_TIER_RATE_LIMIT=600
INSTITUTIONAL_TIER_RATE_LIMIT=6000
