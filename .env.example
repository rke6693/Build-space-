# Market Edge Daily — Environment Configuration
# Copy to .env and fill in your API keys

# OpenAI API key (for LLM research and briefing generation)
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Serper API key (for web search research)
# Get one at: https://serper.dev (free tier: 2500 queries/month)
SERPER_API_KEY=your-serper-key-here

# LLM model to use (default: gpt-4o)
LLM_MODEL=gpt-4o

# LLM temperature for research analysis (lower = more focused)
LLM_TEMPERATURE=0.3

# Newsletter output directory
NEWSLETTER_DIR=~/newsletter

# Prediction tracker database file
TRACKER_DB=~/newsletter/predictions.json

# Accuracy reports directory
ACCURACY_DIR=~/newsletter/accuracy

# Markets resolving within this many days (default: 14)
RESOLUTION_WINDOW_DAYS=14

# Number of top divergence markets to feature (default: 5)
TOP_DIVERGENCE_COUNT=5

# Target words per briefing (default: 500)
BRIEFING_WORD_TARGET=500

# Daily schedule (24h UTC, default: 05:00)
DAILY_RUN_HOUR=5
DAILY_RUN_MINUTE=0
