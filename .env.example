# ---- Core ----
NODE_ENV=development
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-me-32-byte-base64

# ---- Database (Neon / Postgres) ----
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# ---- Email (Resend) ----
RESEND_API_KEY=re_xxx
EMAIL_FROM="Space Runner <auth@example.com>"

# ---- OAuth (optional) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_PRO_YEARLY=price_xxx

# ---- Rate limit (Upstash) ----
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- Anti-cheat HMAC ----
# Generate with: openssl rand -base64 48
RUN_TOKEN_SECRET=replace-me-48-byte-base64

# ---- Daily food-offers email (Vercel Cron) ----
# Vercel auto-injects Authorization: Bearer $CRON_SECRET on scheduled invocations.
# Generate with: openssl rand -hex 32
CRON_SECRET=
DAILY_OFFERS_RECIPIENT=you@example.com
DAILY_OFFERS_ZIP=45103
DAILY_OFFERS_TZ=America/New_York
DAILY_OFFERS_SEND_HOUR=8
# Optional: real offers via Yelp Fusion (https://docs.developer.yelp.com/).
# If unset, the job sends a short curated fallback list so you still get an email.
YELP_API_KEY=
