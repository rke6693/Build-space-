<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Widget reads the same JSON the app writes, via the App Group -->
    <key>com.apple.security.application-groups</key>
    <array>
        <string>group.app.koru.shared</string>
    </array>
    <!-- Widget needs HealthKit read only as a fallback if the JSON is stale -->
    <key>com.apple.developer.healthkit</key>
    <true/>
</dict>
</plist>
