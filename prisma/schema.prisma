// Prisma schema for Space Runner SaaS.
// All mutations from API handlers MUST scope by userId to prevent IDOR.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Auth.js (NextAuth) tables ----------

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  emailVerified DateTime?
  name          String?
  image         String?
  createdAt     DateTime       @default(now())

  accounts      Account[]
  sessions      Session[]
  subscription  Subscription?
  scores        Score[]
  runs          Run[]
  auditLogs     AuditLog[]

  @@index([createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------- Billing ----------

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  INCOMPLETE
  INCOMPLETE_EXPIRED
  UNPAID
  PAUSED
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeCustomerId     String             @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  status               SubscriptionStatus
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
}

// Dedupe table for Stripe webhooks. Unique insert before processing.
model WebhookEvent {
  id          String   @id // Stripe event ID (evt_...)
  type        String
  processedAt DateTime @default(now())

  @@index([type])
}

// ---------- Game ----------

// A server-issued run token. One-shot; marked consumed on score submit.
model Run {
  id         String    @id @default(cuid())
  userId     String
  nonce      String    @unique
  startedAt  DateTime  @default(now())
  expiresAt  DateTime
  consumedAt DateTime?
  score      Score?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt])
}

model Score {
  id        String   @id @default(cuid())
  userId    String
  runId     String   @unique
  value     Int
  durationMs Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  run  Run  @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([value(sort: Desc)])
  @@index([userId, value(sort: Desc)])
}

// ---------- Security / audit ----------

enum AuditEvent {
  LOGIN
  LOGOUT
  CHECKOUT_STARTED
  SUBSCRIPTION_CREATED
  SUBSCRIPTION_UPDATED
  SUBSCRIPTION_CANCELED
  WEBHOOK_REJECTED
  SCORE_REJECTED
  RATE_LIMITED
}

model AuditLog {
  id        String     @id @default(cuid())
  userId    String?
  event     AuditEvent
  ip        String?
  userAgent String?
  meta      Json?
  createdAt DateTime   @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([event, createdAt])
}
